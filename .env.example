# Supabase — project settings > API
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mercado Pago — developers.mercadopago.com > Credenciales de producción
MP_ACCESS_TOKEN=APP_USR-...

# Cron security — any random string, same value in Vercel env vars
CRON_SECRET=your-random-secret

# Mercado Pago webhook secret — se obtiene al registrar el webhook en MP
MP_WEBHOOK_SECRET=your-webhook-secret
